# ================================================
# AI Business Growth OS - Environment Variables
# ================================================

# ==========================================
# 1. 核心基础设施 (Supabase) - 必须有
# ==========================================
# 位置：Supabase 后台 -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================
# 2. 网站基础配置 - 必须有
# ==========================================
# 开发环境填 localhost，上线后填你的域名 (如 https://yumi-ai.com)
# 作用：Supabase 登录后跳回哪里，以及生成分享链接用
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# Dify 智能体矩阵 (v3.0 最终定义)
# 说明：以下是六个核心智能体的 API Key，分别对应不同的业务模块
# 获取方式：Dify 后台 -> 应用 -> 发布 -> API 访问 -> API Key
# ==========================================

# 默认 API Key (fallback，当没有指定特定 Agent Key 时使用)
# 建议设置为天道·战略的 Key
DIFY_API_KEY=your_dify_api_key

# 1. 天道 · 战略 (Strategy & Positioning)
# 职责：方向在哪？做不做？（定位）
DIFY_STRATEGY_KEY=your_strategy_api_key

# 2. 地利 · 产品 (Product & Matrix)
# 职责：卖什么？产品是啥？（产品矩阵）
DIFY_PRODUCT_KEY=your_product_api_key

# 3. 人和 · 模式 (Business Model & Ecosystem)
# 职责：怎么连？团结谁、对抗谁？（商业模式）
DIFY_MODEL_KEY=your_model_api_key

# 4. 神韵 · 内容 (Content & Brand IP)
# 职责：怎么说？内容即流量（品牌IP）
DIFY_CONTENT_KEY=your_content_api_key

# 5. 财帛 · 转化 (Monetization & Conversion)
# 职责：怎么收钱？变现路径（定价策略）
DIFY_MONEY_KEY=your_money_api_key

# 6. 法度 · 风险 (Risk & Compliance)
# 职责：如何不死？什么不能做？（合规边界）
DIFY_LAW_KEY=your_law_api_key

# Dify API Base URL (通常不需要修改)
DIFY_API_URL=https://api.dify.ai/v1

# ==========================================
# SiliconFlow API 配置
# ==========================================
# SiliconFlow 提供多种大模型 API（与 OpenAI 兼容）
# 获取方式：https://cloud.siliconflow.cn/account/ak
# 支持的模型：DeepSeek-R1, GLM-4, Qwen3 等
SILICONFLOW_API_KEY=your_siliconflow_api_key

# 推荐模型配置（可选，默认使用 DeepSeek-R1）
# 语言模型 - 推理
# SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-R1

# 语言模型 - 对话
# SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3
# SILICONFLOW_MODEL=MiniMax/MiniMax-M2.5
# SILICONFLOW_MODEL=MiniMax/MiniMax-M2.1
# SILICONFLOW_MODEL=Pro/zai-org/GLM-4.7

# 语言模型 - 通用
# SILICONFLOW_MODEL=Qwen/Qwen3-72B-Instruct
# SILICONFLOW_MODEL=THUDM/glm-4-9b-chat

# ==========================================
# (可选) 谷歌登录配置
# ==========================================
# 如果你想让用户用 Google 账号一键登录
# 位置：Google Cloud Console -> APIs & Services -> Credentials
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# ==========================================
# 安全与速率限制配置
# ==========================================
# 匿名用户每小时最大请求数（默认: 5）
# ANONYMOUS_RATE_LIMIT=5

# API 请求超时时间（毫秒，默认: 60000 = 60秒）
# API_TIMEOUT=60000

# 流式请求超时时间（毫秒，默认: 120000 = 120秒）
# STREAM_TIMEOUT=120000

# ==========================================
# Redis 配置 (蜂群记忆系统)
# ==========================================
# Redis 连接 URL (格式: redis://[password@]host:port)
# 本地开发: redis://localhost:6379
# 生产环境: redis://username:password@redis-host:6379
REDIS_URL=redis://localhost:6379

# Redis 密码（如果需要）
# REDIS_PASSWORD=your_redis_password

# Redis 数据库编号（默认: 0）
# REDIS_DB=0

# 是否启用 Redis（设为 false 则优雅降级，不影响主流程）
# REDIS_ENABLED=true

# ==========================================
# OpenClaw 传感器配置
# ==========================================
# OpenClaw 网关地址（用于接入外部传感器）
# 获取方式：联系 OpenClaw 团队获取网关地址
OPENCLAW_GATEWAY_URL=https://gateway.openclaw.com

# OpenClaw API Key（用于网关认证）
OPENCLAW_API_KEY=your_openclaw_api_key

# ==========================================
# 外部 API 密钥 (传感器数据源)
# ==========================================
# 法度·风险传感器
LAW_API_KEY=your_law_api_key                    # 法律法规查询 API
NEWS_API_KEY=your_news_api_key                  # 新闻 API（竞品暴雷监测）
AD_LAW_API_KEY=your_ad_law_api_key              # 广告法违禁词 API

# 财帛·转化传感器
AD_COST_API_KEY=your_ad_cost_api_key            # 广告成本查询 API
COMPETITOR_API_KEY=your_competitor_api_key      # 竞品定价 API

# 天道·战略传感器
MARKET_RESEARCH_API_KEY=your_market_research_key # 市场规模 API
INDUSTRY_API_KEY=your_industry_api_key          # 行业趋势 API

# 人和·模式传感器
JOBS_API_KEY=your_jobs_api_key                  # 招聘数据 API
SALARY_API_KEY=your_salary_api_key              # 薪资水平 API
